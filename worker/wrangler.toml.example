name = "app-guard"
main = "src/index.ts"
compatibility_date = "2026-04-30"
migrations_dir = "migrations"

kv_namespaces = [
  { binding = "APP_GUARD_RULES", id = "b9ce049195274634b6dd51430cb79f8c" }
]

[[d1_databases]]
binding = "APP_GUARD_DB"
database_name = "app_guard_events"
database_id = "5637c371-1609-4523-9e0e-d9f8a5e9a62d"

# Set this as a secret instead of plaintext:
# wrangler secret put ADMIN_TOKEN
